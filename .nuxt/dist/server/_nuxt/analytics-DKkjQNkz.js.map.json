{"file":"analytics-DKkjQNkz.js","mappings":";;;;;;;;;;;;;;;;;;;;;AACA,UAAM;AAAA,MACJ;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,MACA;AAAA,IAAA,IACE,uBAAA;AAEJ,eAAW;AAAA,MACT,OAAO;AAAA,MACP,aAAa;AAAA,IAAA,CACd;;;;;;;;AAIM,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,4BAAwB,MAAA,CAAA,CAAA,GAAA;;QAE/B,OAAM;AAAA,QACN,aAAY;AAAA,MAAA;;QAIZ,SAAQ;AAAA,QACR,OAAM;AAAA,QACN,aAAY;AAAA,MAAA;AAGF,YAAAC,mBAAA,sBAAA,EAAA,OAAOC,MAAA,cAAA,EAAA,GAAc,MAAA,OAAA,CAAA;;AAGLC,oBAAAD,MAAA,IAAA,IAAV,WAAM;;UAAW,KAAK,OAAO;AAAA,UAAQ;AAAA,QAAA;;;;QAKnD,OAAM;AAAA,QACN,UAAS;AAAA,QACR,QAAQA,MAAA,qBAAA;AAAA,MAAA;;QAGT,OAAM;AAAA,QACN,UAAS;AAAA,QACR,OAAOA,MAAA,YAAA;AAAA,QACP,oBAAkBA,MAAA,eAAA;AAAA,QAClB,iBAAgBA,MAAA,kBAAA;AAAA,MAAA;;;QAKnB,OAAM;AAAA,QACN,UAAS;AAAA,QACR,QAAQA,MAAA,uBAAA;AAAA,MAAA;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_unref","_ssrRenderList"],"sources":["../../../../pages/analytics.vue"],"sourcesContent":["<script setup lang=\"ts\">\nconst {\n  analyticsStats,\n  channelSplit,\n  filteredOrderLoadSeries,\n  filteredRevenueSeries,\n  kpis,\n  selectedChannel,\n  setSelectedChannel\n} = useBrewlyticsWorkspace()\n\nuseSeoMeta({\n  title: 'Analytics',\n  description: 'Performance analytics for Brewlytics.'\n})\n</script>\n\n<template>\n  <div class=\"space-y-6 sm:space-y-8\">\n    <AppTopbar\n      title=\"Analytics built for the next shift, not last quarter.\"\n      description=\"Track growth, conversion, and demand timing with visuals tuned for operators who need action in minutes.\"\n    />\n\n    <PageHero\n      eyebrow=\"Performance analytics\"\n      title=\"Read demand patterns at a glance and move from reporting to response.\"\n      description=\"Revenue, order pressure, and channel mix are now connected to the live dashboard filter state.\"\n    />\n\n    <StatStrip :items=\"analyticsStats\" />\n\n    <section class=\"data-grid grid-cols-1 md:grid-cols-3\">\n      <KpiCard v-for=\"metric in kpis\" :key=\"metric.title\" :metric=\"metric\" />\n    </section>\n\n    <section class=\"data-grid grid-cols-1 xl:grid-cols-[1.35fr,0.95fr]\">\n      <AreaTrendChart\n        title=\"Weekly revenue curve\"\n        subtitle=\"Gross sales acceleration from Monday through Sunday.\"\n        :points=\"filteredRevenueSeries\"\n      />\n      <ChannelSplitCard\n        title=\"Channel contribution\"\n        subtitle=\"Select a channel to push that view across the dashboard.\"\n        :items=\"channelSplit\"\n        :selected-channel=\"selectedChannel\"\n        @select-channel=\"setSelectedChannel\"\n      />\n    </section>\n\n    <AreaTrendChart\n      title=\"Hourly order pressure\"\n      subtitle=\"Queue intensity over the trading day for the active channel filter.\"\n      :points=\"filteredOrderLoadSeries\"\n    />\n  </div>\n</template>\n"],"version":3}